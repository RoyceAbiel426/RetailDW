                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    t.InvoiceNo AS txn_id,
    TRY_CAST(TRY_CAST(t.CustomerID AS DECIMAL(18,1)) AS INT) AS CustomerID,
    t.StockCode,
    CAST(t.InvoiceDate AS DATE) AS InvoiceDate,
    t.Quantity,
    t.UnitPrice
FROM RetailStaging.dbo.stg_Transactions t
WHERE t.Quantity IS NOT NULL
  AND t.UnitPrice IS NOT NULL
  AND TRY_CAST(TRY_CAST(t.CustomerID AS DECIMAL(18,1)) AS INT) IS NOT NULL
  AND t.StockCode IS NOT NULL
  AND t.InvoiceDate IS NOT NULL
  AND t.InvoiceNo IS NOT NULL;</property>
