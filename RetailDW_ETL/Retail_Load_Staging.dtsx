                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST(t.InvoiceNo AS VARCHAR(50)) AS InvoiceNo,

    t.StockCode,
    p.Description,
    TRY_CAST(t.Quantity AS INT) AS Quantity,
    t.InvoiceDate,
    TRY_CAST(t.Price AS DECIMAL(18,2)) AS UnitPrice,
    TRY_CAST(TRY_CAST(t.CustomerID AS DECIMAL(18,0)) AS INT) AS CustomerID
FROM RetailOLTP.dbo.Transactions t
LEFT JOIN RetailOLTP.dbo.Products p
    ON t.StockCode = p.StockCode
WHERE TRY_CAST(t.Quantity AS INT) IS NOT NULL
  AND TRY_CAST(t.Price AS DECIMAL(18,2)) IS NOT NULL
  AND TRY_CAST(TRY_CAST(t.CustomerID AS DECIMAL(18,0)) AS INT) IS NOT NULL;</property>
